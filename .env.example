# ── Database ──────────────────────────────────────────────────
# Local:   postgresql+asyncpg://classconnect:secret@localhost:5432/classconnect
# AWS RDS: postgresql+asyncpg://user:pass@rds-endpoint:5432/classconnect
DATABASE_URL=postgresql+asyncpg://classconnect:secret@localhost:5432/classconnect

# ── JWT ───────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=change-this-to-64-char-hex-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Google OAuth ──────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=1.0.0
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
